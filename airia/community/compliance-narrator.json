{
  "module_id": "compliance-narrator",
  "name": "Compliance Narrator — AI Decision Audit Trail Generator",
  "version": "1.0.0",
  "description": "Proves to your auditor that AI-handled incidents are more transparent than manual ones. Generates a fully structured post-mortem PDF with a complete AI decision log — every model call, every input, every reasoning trace — plus a DORA/SOX/HIPAA-aligned compliance record. Forkable for any regulated industry.",
  "author": {
    "name": "Manoj Mallick",
    "email": "manoj@learnhubplay.com",
    "organisation": "LearnHubPlay BV"
  },
  "airia_community_url": "https://community.airia.com/agents/compliance-narrator",
  "license": "MIT",
  "source_directory": "community/compliance-narrator/",
  "entry_file": "community/compliance-narrator/index.js",
  "runtime": "nodejs20",
  "airia_features_used": [
    "document_generator",
    "governance_dashboard",
    "compliance_automation",
    "ai_model_call",
    "structured_output"
  ],
  "supported_regulatory_frameworks": [
    {
      "id": "dora",
      "label": "DORA Article 11 — ICT Incident Management",
      "jurisdiction": "EU",
      "module_file": "community/compliance-narrator/frameworks/dora.js"
    },
    {
      "id": "sox",
      "label": "SOX Section 404 — IT General Controls",
      "jurisdiction": "US",
      "module_file": "community/compliance-narrator/frameworks/sox.js"
    },
    {
      "id": "hipaa",
      "label": "HIPAA — Healthcare incidentdocumentation",
      "jurisdiction": "US",
      "module_file": "community/compliance-narrator/frameworks/hipaa.js"
    },
    {
      "id": "fisma",
      "label": "FISMA — Government systems incident records",
      "jurisdiction": "US Federal",
      "module_file": "community/compliance-narrator/frameworks/fisma.js"
    }
  ],
  "document_sections": [
    "1. Incident Summary",
    "2. Incident Timeline",
    "3. AI Decision Audit",
    "4. Regulatory Compliance Record",
    "5. Root Cause & Recommendations",
    "6. Approval Signatures"
  ],
  "fork_use_cases": [
    "Healthcare: HIPAA-compliant incident documentation",
    "Insurance: Claims processing AI decision audit trails",
    "Government: FISMA-aligned AI incident records",
    "Banking: DORA Article 11 ICT incident compliance",
    "Public companies: SOX Section 404 IT controls evidence"
  ],
  "customization_points": {
    "framework_directory": "community/compliance-narrator/frameworks/",
    "sections_directory": "community/compliance-narrator/sections/",
    "description": "Select the regulatory framework(s) for your jurisdiction. Swap out sections. Add your company logo to the PDF template in Airia Document Generator."
  },
  "inputs": {
    "format": "JSON",
    "trigger": "incident resolved",
    "schema": {
      "incident_id": "string",
      "service": "string",
      "severity": "string",
      "triggered_at": "ISO8601",
      "resolved_at": "ISO8601",
      "ai_decisions": "array of AI decision records",
      "hitl_record": "human approval record",
      "timeline_events": "chronological event array"
    }
  },
  "outputs": {
    "primary": "Post-mortem PDF (6 sections)",
    "secondary": "Airia Governance Dashboard entry",
    "tertiary": "Compliance certification record",
    "format": "PDF + JSON"
  },
  "readme_first_line": "Prove to your auditor that AI-handled incidents are more transparent than manual ones.",
  "demo_payload": "community/compliance-narrator/examples/input-resolved.json",
  "demo_output": "community/compliance-narrator/examples/output-postmortem.pdf (committed binary)"
}
