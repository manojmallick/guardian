{
  "node_id": "node-04-warroom",
  "name": "War Room Agent",
  "version": "1.0.0",
  "type": "nested_agent",
  "description": "Activates the incident war room with Slack channel + Jira ticket. Nested agents run in parallel for < 5 second completion.",
  "nested_agents": [
    {
      "id": "slack-warroom-subagent",
      "name": "SlackWarRoomSubAgent",
      "execution": "parallel",
      "entry_file": "sub-agents/slack-warroom-subagent/index.js",
      "responsibilities": [
        "Create Slack incident channel: #inc-{incident_id}-{service}",
        "Post incident summary message with runbook and AI triage",
        "Invite and @mention on-call teams"
      ],
      "mcp_connection": {
        "provider": "slack",
        "server_type": "airia_hosted",
        "server_id": "slack-mcp-server",
        "credentials": { "storage": "airia_vault", "key": "slack-bot-token" }
      }
    },
    {
      "id": "jira-ticket-subagent",
      "name": "JiraTicketSubAgent",
      "execution": "parallel",
      "entry_file": "sub-agents/jira-ticket-subagent/index.js",
      "responsibilities": [
        "Create Jira incident ticket with P1/P2/P3 priority",
        "Attach runbook URL and AI triage summary",
        "Set SLA timer and custom guardian fields",
        "Assign to on-call team owner"
      ],
      "mcp_connection": {
        "provider": "atlassian_jira",
        "server_type": "airia_hosted",
        "server_id": "atlassian-mcp-server",
        "credentials": { "storage": "airia_vault", "key": "atlassian-jira-token" },
        "config": { "project_key": "INC" }
      }
    }
  ],
  "execution_model": "parallel",
  "target_completion_seconds": 5,
  "code": {
    "entry_file": "nodes/node-04-warroom/index.js",
    "runtime": "nodejs20",
    "timeout_seconds": 15
  },
  "https_nodes": [
    {
      "purpose": "Slack channel creation fallback",
      "endpoint": "https://slack.com/api/conversations.create"
    },
    {
      "purpose": "Jira issue creation fallback",
      "endpoint": "https://{JIRA_BASE_URL}/rest/api/3/issue"
    }
  ],
  "resolution_trigger": {
    "sources": [
      { "type": "jira_status_change", "status": "Resolved" },
      { "type": "slack_command",      "command": "/guardian-resolved" }
    ],
    "on_resolve": "trigger_node_05_narrator"
  },
  "structured_output": {
    "schema_file": "nodes/node-04-warroom/schema.js",
    "enforce_schema": true
  },
  "agent_variables": {
    "receive_from_previous": ["incident_id", "service", "severity", "runbooks", "hitl", "reasoning", "alert_raw"],
    "pass_to_next": ["slack_channel", "slack_channel_id", "jira_ticket", "jira_url", "oncall_notified", "warroom_activated_at"]
  }
}
