{
  "node_id": "node-03-hitl",
  "name": "HITL Gate",
  "version": "1.0.0",
  "type": "human_in_the_loop",
  "description": "Mandatory human approval checkpoint before any automated war room action. Satisfies DORA Article 11 human oversight requirement. Uses Airia MCP Apps for interactive Slack UI.",
  "hitl_config": {
    "approval_surface": "slack",
    "approval_channel": "#sre-oncall",
    "timeout_minutes": 15,
    "timeout_action": "auto_escalate",
    "timeout_escalation_channel": "#sre-escalations",
    "timeout_severity_override": "P1",
    "record_approver_identity": true,
    "record_timestamp": true,
    "governance_log": true
  },
  "mcp_apps": {
    "enabled": true,
    "feature": "mcp_apps",
    "launched": "2026-02-12",
    "description": "Interactive UI rendered inside Slack via Model Context Protocol. Provides clickable approve/escalate/reject buttons.",
    "payload_type": "mcp_app_interactive",
    "blocks": {
      "include_header": true,
      "include_section_fields": true,
      "include_context": true,
      "include_runbook_preview": true,
      "include_actions": true
    },
    "buttons": [
      { "id": "approve",  "label": "✅ Approve Response",    "style": "primary" },
      { "id": "escalate", "label": "⬆️ Escalate Severity",   "style": "warning" },
      { "id": "reject",   "label": "❌ Reject (False Alarm)", "style": "danger"  }
    ]
  },
  "slack_bot": {
    "deployment": "airia_slack_bot",
    "scopes": ["channels:write", "chat:write", "users:read", "interactivity"],
    "credentials": {
      "storage": "airia_vault",
      "key": "slack-bot-token"
    }
  },
  "outcomes": {
    "approve":   { "next_node": "node-04-warroom", "severity_unchanged": true  },
    "escalate":  { "next_node": "node-04-warroom", "severity_override": "P1"  },
    "reject":    { "next_node": null, "log_false_alarm": true                  },
    "timeout":   { "next_node": "node-04-warroom", "severity_override": "P1", "flag": "AUTO_ESCALATED" }
  },
  "governance": {
    "audit_event": "HITL_DECISION",
    "record_fields": ["decision", "approver_identity", "timestamp", "response_time_seconds"],
    "regulatory_note": "Satisfies DORA Article 11 human oversight requirement for AI-assisted incident management",
    "dashboard": "airia_governance_dashboard"
  },
  "code": {
    "entry_file": "nodes/node-03-hitl/index.js",
    "runtime": "nodejs20"
  },
  "structured_output": {
    "schema_file": "nodes/node-03-hitl/schema.js",
    "enforce_schema": true
  },
  "agent_variables": {
    "receive_from_previous": ["incident_id", "service", "severity", "runbooks", "reasoning", "alert_raw", "hitl"],
    "pass_to_next": ["hitl"]
  }
}
